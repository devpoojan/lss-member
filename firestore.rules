rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Members and Sequential Counter
    match /members/{memberId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
      
      // Allow access to the history subcollection for admins
      match /history/{historyId} {
        allow read, write: if request.auth != null;
      }
    }
    
    match /system/counter {
      // Allow create so new databases can initialize the counter on first submission
      allow read, update, create: if true;
    }

    // 2. Public Settings (Landing Page)
    match /system/config {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 3. Dropdown Fields (Field Manager)
    match /system/fields {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 4. Default: Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
